# ── Server ──────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=info

# ── Database ────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/dbname

# ── Auth ────────────────────────────────────────────────
JWT_SECRET=opushire_super_secret_key_123
JWT_EXPIRES_IN=7d

# ── SMTP / Email Verification ───────────────────────────
# Example (Outlook / Microsoft 365):
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_email@outlook.com
# SMTP_PASS=your_password_or_app_password
# SMTP_FROM=OpusHire <your_email@outlook.com>
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@outlook.com
SMTP_PASS=your_app_password
SMTP_FROM=OpusHire <your_email@outlook.com>

# ── AI / LLM APIs ──────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
GROQ_API_KEY=your_groq_api_key

# ── Azure Blob Storage (resume uploads) ────────────────
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
AZURE_STORAGE_ACCOUNT=your_storage_account_name
AZURE_STORAGE_KEY=your_storage_account_key

# ── Redis (BullMQ queues) ──────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# For Redis Cloud (redislabs.com), set these:
# REDIS_HOST=redis-xxxxx.c282.east-us-mz.azure.cloud.redislabs.com
# REDIS_PORT=14080
# REDIS_PASSWORD=your_redis_cloud_password
# REDIS_TLS=false  # Use true only if your Redis endpoint/port is TLS-enabled

# Secondary Redis (Upstash) — heavy/bursty jobs (scan-jobs, linkedin-enrich) are
# routed here automatically, keeping Redis Cloud connection count low.
# Upstash free tier supports 100 connections; paid plans support more.
# Leave unset to run everything on the primary Redis.
# SECONDARY_REDIS_HOST=your-upstash-host.upstash.io
# SECONDARY_REDIS_PORT=6379
# SECONDARY_REDIS_PASSWORD=your_upstash_password
# SECONDARY_REDIS_TLS=true   # Upstash requires TLS

# BullMQ worker tuning for low-connection plans:
# BULLMQ_WORKERS_ENABLED=true
# BULLMQ_WORKER_CONCURRENCY=1
# BULLMQ_ENABLE_QUEUE_EVENTS=false
# BULLMQ_SHARED_QUEUE_NAME=opushire-jobs
# BULLMQ_INIT_RETRY_MS=15000

# ── Safety ──────────────────────────────────────────────
# Set to "true" only when you want auto-apply to actually submit applications
AUTO_APPLY_SUBMIT=false
