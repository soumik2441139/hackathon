# Bot uses the same MongoDB as the main OpusHire backend
MONGODB_URI=your_mongodb_connection_string_here
PORT=5001

# Adzuna API (Phase 2)
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_API_KEY=your_adzuna_api_key

# Google Gemini API (used by AI scraper)
GEMINI_API_KEY=your_gemini_api_key_here

# Telegram Channels (Phase 3) — comma-separated public channel usernames
# Leave empty to use defaults: internshala_jobs, freshabordjobs, jobs_and_internships, remote_jobs_feed, workintech
# TELEGRAM_CHANNELS=internshala_jobs,freshabordjobs,my_custom_channel
